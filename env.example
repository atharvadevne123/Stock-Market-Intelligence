# Stock Market Intelligence - Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_ENVIRONMENT=development
API_LOG_LEVEL=INFO

# ============================================================================
# Database Configuration (Optional - for future use)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/stock_intelligence
DATABASE_ECHO=False

# ============================================================================
# Redis Configuration (Optional - for caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=False

# ============================================================================
# News API Configuration (Optional)
# ============================================================================
NEWS_API_KEY=your_newsapi_key_here
NEWSAPI_ENABLED=False

# ============================================================================
# Reddit API Configuration (Optional)
# ============================================================================
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_SECRET=your_reddit_secret
REDDIT_USER_AGENT=StockMarketIntelligence/1.0
REDDIT_ENABLED=False

# ============================================================================
# ML Model Configuration
# ============================================================================
FINBERT_MODEL=ProsusAI/finbert
DEVICE=cpu
USE_GPU=False

# ============================================================================
# Data Retention
# ============================================================================
NEWS_CACHE_HOURS=24
SIGNAL_HISTORY_DAYS=30
SENTIMENT_CACHE_ENABLED=True

# ============================================================================
# Analysis Parameters
# ============================================================================
DEFAULT_HOURS_LOOKBACK=24
BATCH_ANALYSIS_SIZE=10
MAX_ARTICLES_PER_TICKER=50

# ============================================================================
# Security (Optional - for production)
# ============================================================================
API_KEY=your_api_key_here
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
ENABLE_API_KEY_AUTH=False

# ============================================================================
# Celery Configuration (Optional - for background jobs)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_ENABLED=False

# ============================================================================
# Email Configuration (Optional - for alerts)
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_ALERTS_ENABLED=False
